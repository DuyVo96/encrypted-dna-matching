# Copy this file to .env.local and fill in your values.

# Deployed program ID (from: anchor keys list  or  solana address -k target/deploy/encrypted_dna-keypair.json)
NEXT_PUBLIC_PROGRAM_ID=YOUR_PROGRAM_ID_HERE

# Helius devnet RPC — get a free key at https://helius.dev
# The default public devnet RPC rate-limits aggressively; Helius is more reliable.
NEXT_PUBLIC_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
